{
  "name": "nuimarkets/laravel-shared-utils",
  "description": "Common Laravel Classes",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Nui Markets",
      "email": "developers@nuimarkets.com"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": "^8.3",
    "ext-gd": "*",
    "monolog/monolog": "^3.0",
    "laravel/framework": "^10.15|^11.0",
    "sentry/sentry-laravel": "^4.11",
    "guzzlehttp/guzzle": "^7.0",
    "swisnl/json-api-client": "^2.2",
    "aws/aws-sdk-php": "^3.342",
    "intervention/image": "^4.0"
  },
  "suggest": {},
  "scripts": {
    "format": "pint",
    "lint": "pint --test || true",
    "test": "phpunit --filter",
    "test-all": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5|^11.0",
    "orchestra/testbench": "^8.0|^9.0",
    "laravel/pint": "^1.0",
    "mockery/mockery": "^1.6"
  },
  "conflict": {
    "phpunit/phpunit": "<10.5.0"
  },
  "autoload": {
    "psr-4": {
      "NuiMarkets\\LaravelSharedUtils\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NuiMarkets\\LaravelSharedUtils\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
